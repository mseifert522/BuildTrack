# ── Server ──
PORT=3001
NODE_ENV=production

# ── JWT ──
JWT_SECRET=replace_with_a_long_random_secret_string_min_32_chars
BUILDTRACK_SEED_TEMP_PASSWORD=replace_with_initial_setup_password_min_12_chars

# ── Database (SQLite — file path relative to backend/) ──
DB_PATH=./data/buildtrack.db

# ── Email (SMTP) ──
# Used to send invoice PDFs to office and contractor
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="BuildTrack <your_email@gmail.com>"
OFFICE_EMAIL=invoices@newurbandev.com

# ── Inbound invoice email intake ──
# Google Workspace / parser webhooks POST invoice emails here:
#   https://buildtrack.newurbandev.com/api/inbound/invoices
INBOUND_INVOICE_TOKEN=replace_with_random_shared_secret
INBOUND_EMAIL_JSON_LIMIT=25mb
INBOUND_INVOICE_UPLOADS_PATH=./uploads/inbound-invoices

# Gmail API bridge for invoices@newurbandev.com
GMAIL_INVOICE_ENABLED=false
GMAIL_INVOICE_USER=invoices@newurbandev.com
GMAIL_INVOICE_SERVICE_ACCOUNT_KEY_PATH=/run/secrets/buildtrack-invoice-gmail.json
GMAIL_INVOICE_POLL_INTERVAL_MS=300000
GMAIL_INVOICE_STARTUP_DELAY_MS=10000
GMAIL_INVOICE_MAX_RESULTS=20
GMAIL_INVOICE_IMPORTED_LABEL=BuildTrackImported
GMAIL_INVOICE_QUERY=to:invoices@newurbandev.com newer_than:30d

# ── Google Places API ──
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── File Uploads ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
